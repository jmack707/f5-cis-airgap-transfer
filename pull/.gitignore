# =============================================================================
# .gitignore
# =============================================================================

# -------------------------------------
# Secrets — never commit the real file
# -------------------------------------
vault.yaml
.vault-pass

# -----------------------------------------------
# Artifact staging — can reach 15+ GB in size
# -----------------------------------------------
artifacts/

# -----------------------------------------------
# ansible-navigator runtime cache
# -----------------------------------------------
.cache/

# -----------------------------------------------
# Python
# -----------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# -----------------------------------------------
# Editor noise
# -----------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
